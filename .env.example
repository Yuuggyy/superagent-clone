# Configuration Superagent Clone
# Copie ce fichier en .env et remplis les valeurs

# OpenAI API Key (obligatoire pour le chat)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modèle à utiliser (gpt-4o recommandé, gpt-4o-mini pour économiser)
OPENAI_MODEL=gpt-4o

# Port du serveur
PORT=3000

# Optionnel : clé API pour génération d'images (OpenAI DALL-E)
# IMAGE_API_KEY=sk-xxxxxxxx

# Optionnel : WhatsApp Business API (pour connecter le bot sur WhatsApp)
# WHATSAPP_TOKEN=xxxxxxxx
# WHATSAPP_PHONE_ID=xxxxxxxx
# WHATSAPP_VERIFY_TOKEN=xxxxxxxx
