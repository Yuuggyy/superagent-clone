# === Configuration Superagent Clone ===

# --- LLM Provider ---
# Choisis ton provider: groq, openrouter, together, mistral, openai, ollama
# Laisse vide pour auto-détection (prend le premier avec une clé)
LLM_PROVIDER=groq

# --- Groq (GRATUIT — RECOMMANDÉ) ---
# Très rapide, Llama 3.3 70B, moins restrictif qu'OpenAI
# Crée une clé gratuite: https://console.groq.com
GROQ_API_KEY=

# --- OpenRouter (gratuit, multi-modèles) ---
# Plusieurs modèles gratuits dont Llama, Mistral, Gemini
# https://openrouter.ai
OPENROUTER_API_KEY=

# --- Together AI (free credits) ---
# https://api.together.ai
TOGETHER_API_KEY=

# --- Mistral (européen, free tier) ---
# https://console.mistral.ai
MISTRAL_API_KEY=

# --- OpenAI (payant, guardrails intégrés) ---
# https://platform.openai.com
OPENAI_API_KEY=

# --- Ollama (LOCAL — 100% gratuit, sur ton PC) ---
# Installe: https://ollama.com
# Pas besoin de clé, tourne en local
# OLLAMA_API_KEY=ollama

# --- Modèle (optionnel, sinon utilise le défaut du provider) ---
# OPENAI_MODEL=llama-3.3-70b-versatile

# --- Serveur ---
PORT=3000
